# PostgreSQL source
PG_URL=postgresql://user:password@localhost:5432/erp_db

# Neo4j target
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ETL tuning
BATCH_SIZE=5000
NUM_WORKERS=8
CHUNK_SIZE=100000

# CDC sync
CDC_POLL_INTERVAL=10
CDC_WATERMARK_TABLE=_erp2neo4j_watermarks

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/erp2neo4j.log
